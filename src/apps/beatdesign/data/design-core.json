    {
      "id": "concept-service-discovery",
      "title": "Service Discovery",
      "description": "Service discovery lets microservices find each other via a registry (e.g. Consul, Eureka).  Each service registers its host/port with the registry, and clients query it to locate service instances dynamically.  This decouples direct IP addresses and enables autoscaling.  For example, Netflix Eureka or Kubernetes DNS can be used so that when a new instance starts, it registers itself and becomes discoverable to others.",
      "estimatedMinutes": 60,
      "difficulty": "Intermediate",
      "category": "Core Fundamentals",
      "orderIndex": 13,
