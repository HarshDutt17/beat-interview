    {
      "id": "concept-message-queues",
      "title": "Message Queues",
      "description": "Message queues (e.g. RabbitMQ, AWS SQS, Kafka) enable asynchronous processing by decoupling producers and consumers.  Producers place messages on a queue, and consumers process them at their own pace. This improves resilience (messages are retried until processed) and scalability (work can be distributed across multiple consumers). It also smooths traffic spikes by buffering requests between services. Enhanced with additional resources and perspectives.",
      "estimatedMinutes": 60,
      "difficulty": "Intermediate",
      "category": "Core Fundamentals",
