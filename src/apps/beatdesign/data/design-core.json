    {
      "id": "concept-scalability",
      "title": "Scalability",
      "description": "Scalability is a system’s ability to handle growing load by expanding resources.  Architecting for scalability often means horizontal scaling (adding more machines) and designing stateless/microservices components to handle higher traffic.  Cloud-native designs use elastic load balancers, CDNs, and caching to meet demand spikes with minimal performance degradation.",
      "estimatedMinutes": 90,
      "difficulty": "Beginner",
      "category": "Core Fundamentals",
      "orderIndex": 0,
