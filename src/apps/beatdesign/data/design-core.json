    {
      "id": "concept-replication",
      "title": "Replication",
      "description": "Replication copies data across multiple machines for reliability and read-scalability.  By maintaining replicas (e.g. master-slave or multi-master), a system can continue serving reads if one node fails and improve read throughput.  For example, a database might replicate writes to multiple data centers for high availability and use read replicas to scale query load.  Replication ensures fault tolerance and can reduce latency via geo-replicas.",
      "estimatedMinutes": 60,
      "difficulty": "Beginner",
      "category": "Core Fundamentals",
      "orderIndex": 6,
      "resources": [
