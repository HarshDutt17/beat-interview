    {
      "id": "concept-distributed-tracing",
      "title": "Distributed Tracing",
      "description": "Distributed tracing records the path of a request across multiple microservices, measuring latency at each step.  It creates traces composed of spans for each service call.  For example, using OpenTelemetry or Zipkin, a trace ID is propagated so you can see a user request’s end-to-end flow and pinpoint slow components.  Tracing is often tied with monitoring and critical for debugging performance issues in microservices.",
      "estimatedMinutes": 60,
      "difficulty": "Advanced",
      "category": "Core Fundamentals",
      "orderIndex": 15,
